    "indent-string": "latest",
    "ink": "latest",
    "jsonc-parser": "latest",
    "lodash-es": "latest",
    "lru-cache": "latest",
    "marked": "latest",
    "openai": "latest",
    "p-map": "latest",
    "picomatch": "latest",
