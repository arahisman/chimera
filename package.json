{
  "name": "chimera-code",
  "version": "0.1.0-alpha.0",
  "description": "Terminal-first coding agent with ChatGPT/Codex OAuth and provider-native model support",
  "type": "module",
  "license": "MIT",
  "author": "arahisman",
  "homepage": "https://github.com/arahisman/chimera#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arahisman/chimera.git"
  },
  "bugs": {
    "url": "https://github.com/arahisman/chimera/issues"
  },
  "keywords": [
    "chimera",
    "codex",
    "chatgpt",
    "openai",
    "openrouter",
    "xai",
    "mcp",
    "tui",
    "coding-agent",
    "agentic-coding",
    "cli"
  ],
  "packageManager": "bun@1.2.18",
  "engines": {
    "bun": ">=1.2.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chimera": "bin/chimera"
  },
  "files": [
    "bin/**",
    "dist/**",
    "!dist/**/*.map",
    "local-packages/**",
    "README.md",
    "LICENSE",
    "docs/packaging.md"
  ],
  "scripts": {
    "deps:audit": "bun scripts/audit-deps.mjs",
    "check": "tsc --noEmit",
    "check:core": "tsc -p tsconfig.codex-core.json --noEmit",
    "check:full": "tsc -p tsconfig.codex-full.json --noEmit",
    "build": "bun scripts/build.mjs",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check:full && bun run test:codex && bun run build",
    "publish:dry-run": "bun run check:full && bun run test:codex && bun run smoke:codex-package && npm publish --dry-run",
    "smoke:codex": "bun run build && bun scripts/smoke-chimera.mjs",
    "smoke:codex-login": "bun run build && bun scripts/smoke-codex-login.mjs",
    "smoke:codex-turn": "bun run build && bun scripts/smoke-codex-turn.mjs",
    "smoke:codex-tool": "bun run build && bun scripts/smoke-codex-tool.mjs",
    "smoke:codex-daily-cli": "bun run build && bun scripts/smoke-codex-daily-cli.mjs",
    "smoke:codex-local-tools": "bun run build && bun scripts/smoke-codex-local-tools.mjs",
    "smoke:codex-session-cli": "bun run build && bun scripts/smoke-codex-session-cli.mjs",
    "smoke:codex-long-session": "bun run build && bun scripts/smoke-codex-long-session.mjs",
    "smoke:codex-compact-modules": "bun scripts/smoke-codex-compact-modules.mjs",
    "smoke:codex-experience": "bun run build && bun scripts/smoke-codex-experience.mjs",
    "smoke:codex-agent": "bun run build && bun scripts/smoke-codex-agent.mjs",
    "smoke:codex-multi-agent": "bun run build && bun scripts/smoke-codex-multi-agent.mjs",
    "smoke:codex-tui": "bun run build && bun scripts/smoke-codex-tui.mjs",
    "smoke:codex-lsp": "bun run build && bun scripts/smoke-codex-lsp.mjs",
    "smoke:codex-image": "bun run build && bun scripts/smoke-codex-image.mjs",
    "smoke:codex-web-search": "bun run build && bun scripts/smoke-codex-web-search.mjs",
    "smoke:codex-computer-use": "bun run build && bun scripts/smoke-codex-computer-use.mjs",
    "smoke:codex-security": "bun run build && bun scripts/smoke-codex-security.mjs",
    "smoke:codex-package": "bun run build && bun scripts/package-smoke.mjs",
    "smoke:codex-plugins": "bun run build && bun scripts/smoke-codex-plugins.mjs",
    "smoke:codex-hooks": "bun run build && bun scripts/smoke-codex-hooks.mjs",
    "smoke:no-cloud-surfaces": "bun scripts/smoke-no-cloud-surfaces.mjs",
    "smoke:no-local-unavailable": "bun scripts/smoke-no-local-unavailable.mjs",
    "smoke:chimera-local-clean": "bun run smoke:no-cloud-surfaces && bun run smoke:no-local-unavailable && bun run build && bun run check:core && bun run check:full && bun run test:codex && bun scripts/smoke-chimera.mjs && bun scripts/smoke-codex-tui.mjs && bun scripts/smoke-codex-plugins.mjs",
    "live:codex-contract": "CHIMERA_LIVE=1 bun scripts/live-codex-contract.mjs",
    "live:codex-models": "CHIMERA_LIVE=1 bun scripts/live-codex-models.mjs",
    "live:codex-turn": "bun run build && CHIMERA_LIVE=1 bun scripts/live-codex-turn.mjs",
    "live:codex-tool": "CHIMERA_LIVE=1 bun scripts/live-codex-tool.mjs",
    "live:codex-voice": "CHIMERA_LIVE=1 bun scripts/live-codex-voice.mjs",
    "test:codex": "bun test src/ide src/services/codex src/services/native src/services/openai src/services/providers src/codex src/query.codex-tool-loop.test.ts src/constants/system.codex.test.ts src/entrypoints/sdk/sdkTypes.codex.test.ts src/services/api/providerMode.codex.test.ts src/tools/AgentTool/builtInAgents.codex.test.ts src/tools/BashTool/bashPermissions.codex.test.ts src/utils/autoUpdater.codex.test.ts src/utils/claudemd.codex.test.ts src/utils/configImport.codex.test.ts src/utils/configPaths.codex.test.ts src/utils/context.codex.test.ts src/utils/permissions/permissions.codex.test.ts src/utils/settingsProjectPaths.codex.test.ts src/utils/computerUse/browserTarget.test.ts src/utils/computerUse/codexLoop.test.ts src/utils/imagePaste.codex.test.ts src/utils/model/codexModelUx.test.ts src/utils/model/providerModelValidation.test.ts src/native-ts/color-diff/colorDiff.codex.test.ts src/utils/semanticNumber.test.ts",
    "start": "bun run build && bun dist/chimera.js"
  },
  "dependencies": {
    "bundle": "file:local-packages/bundle"
  },
