    "signal-exit": "latest",
    "stack-utils": "latest",
    "strip-ansi": "latest",
    "supports-hyperlinks": "latest",
    "tree-kill": "latest",
    "turndown": "latest",
    "type-fest": "latest",
    "typescript": "latest",
    "undici": "latest",
    "usehooks-ts": "latest",
    "vscode-jsonrpc": "latest",
    "vscode-languageserver-protocol": "latest",
